# Credenciales del emulador local de Supabase
# Copia este archivo a .env.local y actualiza los valores con los que
# devuelve `supabase start` o `supabase status`

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<anon-key-del-emulador>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-del-emulador>
